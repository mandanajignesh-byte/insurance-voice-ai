# ============================================================
# LLM APIs
# ============================================================
GROQ_API_KEY=your_key_here        # https://console.groq.com — free tier, primary agent LLM for Q1 and signal LLM for Q4
GEMINI_API_KEY=your_key_here      # https://aistudio.google.com — free tier, primary agent LLM for Q3 (multilingual)

# ============================================================
# Speech APIs
# ============================================================
DEEPGRAM_API_KEY=your_key_here    # https://deepgram.com — $200 signup credit, streaming ASR for Q4 only
# Edge TTS requires no API key (uses unofficial edge-tts Python package)

# ============================================================
# Retrieval
# ============================================================
COHERE_API_KEY=your_key_here      # https://cohere.com — free tier 1000 reranks/month
QDRANT_URL=http://localhost:6333  # local Qdrant HTTP endpoint
QDRANT_GRPC_URL=http://localhost:6334
KB_API_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Ingestion
# ============================================================
FIRECRAWL_API_KEY=your_key_here   # https://firecrawl.dev — free tier 500 pages/month

# ============================================================
# Runtime
# ============================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
